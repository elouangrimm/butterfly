{
    "name": "butterfly-server",
    "version": "1.0.0",
    "description": "Butterfly local API server (Tauri sidecar)",
    "type": "module",
    "main": "index.js",
    "scripts": {
        "start": "node index.js",
        "build:linux": "npx --yes @yao-pkg/pkg index.js --target node20-linux-x64 --no-bytecode --public --public-packages '*' --output ../src-tauri/binaries/butterfly-server-x86_64-unknown-linux-gnu",
        "build:win": "npx --yes @yao-pkg/pkg index.js --target node20-win-x64 --no-bytecode --public --public-packages '*' --output ../src-tauri/binaries/butterfly-server-x86_64-pc-windows-msvc.exe",
        "build:mac": "npx --yes @yao-pkg/pkg index.js --target node20-macos-x64 --no-bytecode --public --public-packages '*' --output ../src-tauri/binaries/butterfly-server-x86_64-apple-darwin"
    },
    "dependencies": {
        "express": "^4.21.0",
        "pawnote": "latest"
    }
}
