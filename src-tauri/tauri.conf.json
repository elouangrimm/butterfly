{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Butterfly",
    "version": "1.0.0",
    "identifier": "dev.elouan.butterfly",

    "build": {
        "frontendDist": "../",
        "devUrl": "http://localhost:1420",
        "beforeDevCommand": "",
        "beforeBuildCommand": ""
    },

    "app": {
        "windows": [
            {
                "label": "main",
                "title": "Butterfly",
                "url": "index.html",
                "width": 1200,
                "height": 800,
                "minWidth": 900,
                "minHeight": 600,
                "resizable": true,
                "fullscreen": false,
                "decorations": true,
                "center": true
            }
        ],
        "security": {
            "csp": null,
            "dangerousDisableAssetCspModification": true
        }
    },

    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "externalBin": ["binaries/butterfly-server"],
        "linux": {
            "deb": {
                "depends": [
                    "libwebkit2gtk-4.1-0",
                    "libgtk-3-0",
                    "libsoup-3.0-0",
                    "libglib2.0-0"
                ]
            }
        },
        "resources": []
    }
}
